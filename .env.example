# Copy to .env and fill in. NEVER commit .env.
# .env is gitignored.

# ---- Grafana ----
# Initial admin password (you'll change it on first login anyway)
GRAFANA_ADMIN_PASSWORD=changeme-on-first-login

# ---- Telegram alerts ----
# Get TELEGRAM_BOT_TOKEN from @BotFather on Telegram
# Get TELEGRAM_CHAT_ID by messaging your bot then visiting:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Network context (used by dashboards / hostname enrichment) ----
# Your home network CIDR(s), comma-separated. Used by Suricata HOME_NET.
HOME_NET=192.168.1.0/24

# Interface Suricata listens on (the port-mirror destination interface on the Pi)
SURICATA_INTERFACE=eth0

# ---- Storage ----
# Directory where all SIEM data lives (Suricata eve.json, Loki chunks, Grafana
# db). This is on the Pi's microSD card — no external drive needed for the
# DNS+alerts workload (~5-15GB over 90 days on a 128GB card).
# If you later add a USB SSD, mount it and point this at its mountpoint instead.
LOG_MOUNT=/var/lib/siem
