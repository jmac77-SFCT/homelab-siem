{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Which device on the home network is calling where, and is any of it suspicious? Sourced from Suricata eve.json (alerts + DNS) shipped via Promtail to Loki.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["homelab-siem", "suricata", "network"],
  "templating": {
    "list": [
      {
        "name": "device",
        "label": "Source device",
        "description": "Filter to one source IP (device), or All.",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({job=\"suricata\"}, device)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".+",
        "multi": false,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Devices Calling Out",
  "uid": "devices-calling-out",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Alerts",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Suricata alerts over time",
      "description": "Count of Suricata IDS alerts per interval. Spikes = something matched a rule.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({job=\"suricata\", event_type=\"alert\", device=~\"$device\"} [$__auto]))",
          "legendFormat": "alerts",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total alerts (range)",
      "description": "Total alert events in the selected time range.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({job=\"suricata\", event_type=\"alert\", device=~\"$device\"} [$__range]))",
          "instant": true,
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Recent alerts (signature, src → dest)",
      "description": "Most recent Suricata alerts with the rule that fired and the device involved.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": { "custom": { "filterable": true } },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"suricata\", event_type=\"alert\", device=~\"$device\"} | json | line_format \"{{.device}} ({{.src_ip}}) -> {{.dest_ip}} :: {{.alert_signature}}\"",
          "queryType": "range",
          "maxLines": 200
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": { "source": "Line" }
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Devices calling out (DNS)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "id": 11,
      "type": "table",
      "title": "Top destinations by source device",
      "description": "Which domains each device is looking up, ranked by query count. With DNS-only logging this is the 'who is each device calling' view (resolved names, not raw flow IPs).",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 11, "w": 14, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": { "custom": { "filterable": true, "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "displayName", "value": "queries" }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "queries", "desc": true }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "topk(50, sum by (device, rrname) (count_over_time({job=\"suricata\", event_type=\"dns\", device=~\"$device\"} | json | rrname!=\"\" [$__range])))",
          "instant": true,
          "queryType": "instant",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": { "mode": "columns" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "device": 0, "rrname": 1, "Value": 2 },
            "renameByName": { "device": "device", "rrname": "domain" }
          }
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "DNS queries by device",
      "description": "DNS query volume per source device over time. A device suddenly querying a lot can be worth a look.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 11, "w": 10, "x": 14, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (device) (count_over_time({job=\"suricata\", event_type=\"dns\", device=~\"$device\"} [$__auto]))",
          "legendFormat": "{{device}}",
          "queryType": "range"
        }
      ]
    }
  ]
}
